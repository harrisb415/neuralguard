<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NeuralGuard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NeuralGuard"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:prim="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NeuralGuard">

    <Grid RowDefinitions="Auto,*">
        <Grid.Resources>
            <!-- Column-resize grip: a ColumnGrip control (shows the resize cursor on hover)
                 drawn as a thin divider; the drag is handled by the pointer events. -->
            <Style x:Key="GripStyle" TargetType="local:ColumnGrip">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="local:ColumnGrip">
                            <Border Background="Transparent">
                                <Rectangle Width="2" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                           HorizontalAlignment="Center" Margin="0,7"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Command bar -->
        <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="8"
              ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="NeuralGuard" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Grid.Column="1" Content="Enforce" Click="OnEnforce" Style="{StaticResource AccentButtonStyle}"/>
            <Button Grid.Column="2" Content="Learn" Click="OnLearn"/>
            <Button Grid.Column="3" Content="Stop" Click="OnStop"/>
            <Button Grid.Column="4" Content="Panic" Click="OnPanic" HorizontalAlignment="Left"/>
            <muxc:InfoBadge Grid.Column="5" x:Name="ModeBadge" Style="{StaticResource InformationalDotInfoBadgeStyle}"
                            VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Grid.Column="6" x:Name="ModeText" Text="idle" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Navigation + content -->
        <muxc:NavigationView Grid.Row="1" x:Name="Nav"
                             PaneDisplayMode="Left" OpenPaneLength="180"
                             IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                             SelectionChanged="OnNavChanged">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Live"    Tag="live" IsSelected="True">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE9D9;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Rules"   Tag="rules">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE71C;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Habits"  Tag="habits">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE9F5;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Per-app" Tag="apps">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE71D;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="History" Tag="history">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE81C;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Flows" Tag="flows">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE9D9;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>
            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="Settings" Tag="settings">
                    <muxc:NavigationViewItem.Icon><muxc:FontIcon Glyph="&#xE713;"/></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <Grid x:Name="ContentRoot" Padding="24,16" RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" x:Name="ViewTitle" Text="Live" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" x:Name="RulesTools" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed">
                        <Button Content="Export" Click="OnExportRules"/>
                        <Button Content="Import" Click="OnImportRules"/>
                    </StackPanel>
                    <AutoSuggestBox Grid.Column="2" x:Name="SearchBox" Width="260" VerticalAlignment="Center"
                                    PlaceholderText="Filter" QueryIcon="Find" TextChanged="OnSearchChanged"/>
                </Grid>

                <!-- Resizable + sortable column headers. Each header cell is a full-width
                     transparent Border (tap anywhere to sort); a visible grip on the right
                     edge drags to resize. -->
                <Border Grid.Row="1" x:Name="HeaderCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" Padding="12,0,0,0">
                    <Grid x:Name="HeaderRow" Height="34">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="HCol0" Width="110"/>
                            <ColumnDefinition x:Name="HCol1" Width="110"/>
                            <ColumnDefinition x:Name="HCol2" Width="240"/>
                            <ColumnDefinition x:Name="HCol3" Width="320"/>
                            <ColumnDefinition x:Name="HCol4" Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" Background="Transparent" Tag="0" Tapped="OnHeaderTap">
                                <TextBlock x:Name="H0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <local:ColumnGrip Grid.Column="1" Tag="0" Style="{StaticResource GripStyle}"
                                              PointerPressed="OnGripPressed" PointerMoved="OnGripMoved"
                                              PointerReleased="OnGripReleased" PointerCanceled="OnGripReleased"
                                              PointerCaptureLost="OnGripReleased"/>
                        </Grid>
                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" Background="Transparent" Tag="1" Tapped="OnHeaderTap">
                                <TextBlock x:Name="H1" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <local:ColumnGrip Grid.Column="1" Tag="1" Style="{StaticResource GripStyle}"
                                              PointerPressed="OnGripPressed" PointerMoved="OnGripMoved"
                                              PointerReleased="OnGripReleased" PointerCanceled="OnGripReleased"
                                              PointerCaptureLost="OnGripReleased"/>
                        </Grid>
                        <Grid Grid.Column="2" ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" Background="Transparent" Tag="2" Tapped="OnHeaderTap">
                                <TextBlock x:Name="H2" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <local:ColumnGrip Grid.Column="1" Tag="2" Style="{StaticResource GripStyle}"
                                              PointerPressed="OnGripPressed" PointerMoved="OnGripMoved"
                                              PointerReleased="OnGripReleased" PointerCanceled="OnGripReleased"
                                              PointerCaptureLost="OnGripReleased"/>
                        </Grid>
                        <Grid Grid.Column="3" ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" Background="Transparent" Tag="3" Tapped="OnHeaderTap">
                                <TextBlock x:Name="H3" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <local:ColumnGrip Grid.Column="1" Tag="3" Style="{StaticResource GripStyle}"
                                              PointerPressed="OnGripPressed" PointerMoved="OnGripMoved"
                                              PointerReleased="OnGripReleased" PointerCanceled="OnGripReleased"
                                              PointerCaptureLost="OnGripReleased"/>
                        </Grid>
                        <Border Grid.Column="4" Background="Transparent" Tag="4" Tapped="OnHeaderTap">
                            <TextBlock x:Name="H4" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <ListView Grid.Row="2" x:Name="DataList" SelectionMode="Single"
                          IsRightTapEnabled="True" RightTapped="OnRowRightTapped"
                          ContainerContentChanging="OnContainerChanging"
                          ItemContainerTransitions="{x:Null}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,3"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Row">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind C0}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind C1}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind C2}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind C3}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind C4}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Settings form (shown instead of the data table for the Settings view). -->
                <ScrollViewer Grid.Row="2" x:Name="SettingsPanel" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24" MaxWidth="620" HorizontalAlignment="Left" Margin="0,4,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Autonomy" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="What NeuralGuard does when an app makes a new outbound connection while enforcing."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            <RadioButton x:Name="Auto0" Tag="0" GroupName="autonomy" Checked="OnAutonomyChanged"
                                         Content="Prompt me on every new connection"/>
                            <RadioButton x:Name="Auto1" Tag="1" GroupName="autonomy" Checked="OnAutonomyChanged"
                                         Content="Auto-allow apps I already use, prompt for the rest"/>
                            <RadioButton x:Name="Auto2" Tag="2" GroupName="autonomy" Checked="OnAutonomyChanged"
                                         Content="Auto-allow everything (log only, no prompts)"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Background service" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Run enforcement as a Windows service (LocalSystem, auto-start) so it keeps guarding after you log off or reboot."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SvcStatus" Text="Checking..." FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Content="Install service" Click="OnServiceInstall" Style="{StaticResource AccentButtonStyle}"/>
                                <Button Content="Remove service" Click="OnServiceRemove"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Machine learning" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Learn a baseline from your completed connections and score new ones for anomalies. Scoring is advisory in Shadow mode - it is logged (see the Flows view) and never blocks anything."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            <ToggleSwitch x:Name="FeatureToggle" Header="Collect flow features"
                                          OnContent="On" OffContent="Off" Toggled="OnFeatureToggle"/>
                            <TextBlock Text="Scoring mode" Margin="0,8,0,0" FontWeight="SemiBold"/>
                            <RadioButton x:Name="Ml0" Tag="off" GroupName="mlmode" Checked="OnMlModeChanged"
                                         Content="Off - don't score"/>
                            <RadioButton x:Name="Ml1" Tag="shadow" GroupName="mlmode" Checked="OnMlModeChanged"
                                         Content="Shadow - score and log only, no effect on rules"/>
                            <RadioButton x:Name="Ml2" Tag="active" GroupName="mlmode" Checked="OnMlModeChanged"
                                         Content="Active - a strongly-malicious score can demote a trusted app so it prompts again"/>
                            <TextBlock Text="Active never auto-blocks: a demoted app simply loses its automatic pass and asks you the next time it connects, exactly like a brand-new app. Only enable this once the models are trained on your own traffic - the shipped models are placeholders. Demotions show under Flows; clear them with `ngd features clear`."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" Margin="24,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Transient status toast (auto-dismisses); floats centred at the
                     bottom over the list. Severity fill brushes are overridden to
                     opaque so the window's Mica/desktop doesn't show through. Single
                     element, sized to its content, so nothing is left behind on close. -->
                <muxc:InfoBar Grid.Row="2" x:Name="Toast"
                              IsOpen="False" IsClosable="True"
                              VerticalAlignment="Bottom" HorizontalAlignment="Center"
                              MaxWidth="680" Margin="0,0,0,24" FontSize="15">
                    <muxc:InfoBar.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="InfoBarInformationalSeverityBackgroundBrush" Color="#EFF4FB"/>
                                    <SolidColorBrush x:Key="InfoBarSuccessSeverityBackgroundBrush" Color="#DFF6DD"/>
                                    <SolidColorBrush x:Key="InfoBarWarningSeverityBackgroundBrush" Color="#FFF4CE"/>
                                    <SolidColorBrush x:Key="InfoBarErrorSeverityBackgroundBrush" Color="#FDE7E9"/>
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Dark">
                                    <SolidColorBrush x:Key="InfoBarInformationalSeverityBackgroundBrush" Color="#2A2E34"/>
                                    <SolidColorBrush x:Key="InfoBarSuccessSeverityBackgroundBrush" Color="#1B3A22"/>
                                    <SolidColorBrush x:Key="InfoBarWarningSeverityBackgroundBrush" Color="#3A3417"/>
                                    <SolidColorBrush x:Key="InfoBarErrorSeverityBackgroundBrush" Color="#3E2A2B"/>
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>
                        </ResourceDictionary>
                    </muxc:InfoBar.Resources>
                </muxc:InfoBar>
            </Grid>
        </muxc:NavigationView>
    </Grid>
</Window>
